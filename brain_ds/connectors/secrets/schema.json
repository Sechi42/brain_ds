{
  "schema_version": "1.0",
  "manifest_path": ".brain_ds/secrets.json",
  "values_path": ".brain_ds/secrets.values.json",
  "entry_required_fields": [
    "handle",
    "kind",
    "metadata",
    "created_at"
  ],
  "provider_kinds": {
    "postgres": {
      "required": [
        "host",
        "port",
        "database",
        "username",
        "sslmode",
        "secret_ref"
      ],
      "types": {
        "host": "string",
        "port": "integer",
        "database": "string",
        "username": "string",
        "sslmode": "string",
        "secret_ref": "string"
      },
      "enums": {
        "sslmode": ["disable", "allow", "prefer", "require", "verify-ca", "verify-full"]
      }
    },
    "sqlserver": {
      "required": [
        "host",
        "port",
        "database",
        "username",
        "sslmode",
        "secret_ref"
      ],
      "types": {
        "host": "string",
        "port": "integer",
        "database": "string",
        "username": "string",
        "sslmode": "string",
        "secret_ref": "string"
      },
      "enums": {
        "sslmode": ["disable", "allow", "prefer", "require", "verify-ca", "verify-full"]
      }
    },
    "aws-google-sheets": {
      "required": [
        "secret_id",
        "spreadsheet_id",
        "sheet_range"
      ],
      "types": {
        "region": "string",
        "secret_id": "string",
        "spreadsheet_id": "string",
        "sheet_range": "string"
      },
      "requires_raw_value": false,
      "descriptions": {
        "region": "AWS region where the secret is stored (optional, default us-east-2)",
        "secret_id": "ARN or name of the service-account secret in AWS Secrets Manager",
        "spreadsheet_id": "Google Sheets spreadsheet ID (from the URL)",
        "sheet_range": "Default cell range to read, e.g. Sheet1!A1:Z"
      },
      "placeholders": {
        "region": "us-east-2",
        "secret_id": "arn:aws:secretsmanager:us-east-2:123456789012:secret:gsheets/service-account",
        "spreadsheet_id": "1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms",
        "sheet_range": "Sheet1!A1:Z"
      }
    },
    "aws-postgres": {
      "required": [
        "secret_id",
        "database"
      ],
      "types": {
        "region": "string",
        "secret_id": "string",
        "database": "string"
      },
      "requires_raw_value": false,
      "descriptions": {
        "region": "AWS region where the secret is stored (optional, default us-east-2)",
        "secret_id": "ARN or name of the RDS secret in AWS Secrets Manager",
        "database": "Database name — declared at registration, not inferred from the AWS payload"
      },
      "placeholders": {
        "region": "us-east-2",
        "secret_id": "arn:aws:secretsmanager:us-east-2:123456789012:secret:prod/rds/postgres",
        "database": "prod_app"
      }
    },
    "aws-secrets": {
      "required": [
        "region",
        "secret_id"
      ],
      "types": {
        "region": "string",
        "secret_id": "string"
      },
      "requires_raw_value": false,
      "descriptions": {
        "region": "AWS region where the secret is stored, e.g. us-east-1",
        "secret_id": "ARN or name of the secret in AWS Secrets Manager"
      },
      "placeholders": {
        "region": "us-east-1",
        "secret_id": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/db/password"
      },
      "picker": {
        "visible": false,
        "label": "Legacy AWS Secrets Manager (existing handles only)"
      }
    },
    "iam-role": {
      "required": [
        "role_arn"
      ],
      "types": {
        "role_arn": "string"
      }
    },
    "iam-credential": {
      "required": [
        "access_key_id",
        "session_token_ref"
      ],
      "types": {
        "access_key_id": "string",
        "session_token_ref": "string"
      }
    },
    "google-sheets-json": {
      "required": [
        "spreadsheet_id",
        "sheet_range"
      ],
      "types": {
        "sheet_range": "string",
        "spreadsheet_id": "string",
        "service_account_ref": "string",
        "credential_type": "string",
        "project_id": "string",
        "gid": "string",
        "email_fingerprint": "string",
        "key_id_fingerprint": "string",
        "universe_domain": "string"
      },
      "ui_fields": {
        "spreadsheet_url": "string",
        "sheet_range": "string"
      },
      "requires_raw_value": true,
      "raw_value_label": "Google service-account JSON",
      "raw_value_placeholder": "{\"type\":\"service_account\",\"project_id\":\"...\",\"private_key_id\":\"...\",\"private_key\":\"-----BEGIN PRIVATE KEY-----\\n...\",\"client_email\":\"service-account@project.iam.gserviceaccount.com\",\"client_id\":\"...\",\"auth_uri\":\"https://accounts.google.com/o/oauth2/auth\",\"token_uri\":\"https://oauth2.googleapis.com/token\",\"auth_provider_x509_cert_url\":\"https://www.googleapis.com/oauth2/v1/certs\",\"client_x509_cert_url\":\"https://www.googleapis.com/robot/v1/metadata/x509/...\",\"universe_domain\":\"googleapis.com\"}",
      "metadata_derivations": {
        "spreadsheet_id": "spreadsheet_url"
      },
      "descriptions": {
        "spreadsheet_url": "Google Sheets URL containing /spreadsheets/d/{spreadsheetId}",
        "spreadsheet_id": "Google Sheets spreadsheet ID parsed from spreadsheet_url and stored after upload",
        "gid": "Optional worksheet gid parsed from query or fragment",
        "sheet_range": "Default cell range to read, e.g. Sheet1!A1:Z"
      },
      "placeholders": {
        "spreadsheet_url": "https://docs.google.com/spreadsheets/d/1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms/edit?gid=0#gid=0",
        "sheet_range": "Sheet1!A1:Z"
      }
    },
    "mock-postgres": {
      "required": [
        "host",
        "port",
        "database",
        "username",
        "sslmode"
      ],
      "types": {
        "host": "string",
        "port": "integer",
        "database": "string",
        "username": "string",
        "sslmode": "string"
      },
      "enums": {
        "sslmode": ["disable", "allow", "prefer", "require", "verify-ca", "verify-full"]
      }
    },
    "mock-google-sheets-json": {
      "required": [
        "spreadsheet_id",
        "sheet_range",
        "service_account_ref"
      ],
      "types": {
        "spreadsheet_id": "string",
        "sheet_range": "string",
        "service_account_ref": "string"
      }
    },
    "sqlite": {
      "required": [
        "path"
      ],
      "types": {
        "path": "string"
      }
    }
  }
}
